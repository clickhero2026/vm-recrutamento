# ──────────────────────────────────────────────────────────────
# Vendedor Mestre - Recrutamento Automatico
# Copie este arquivo para .env e preencha. NUNCA comite o .env real.
# ──────────────────────────────────────────────────────────────

# Servidor
PORT=3000
DATABASE_PATH=./data/app.db
SESSION_SECRET=troque-isto
AGENT_NAME=Vera
RECRUITER_EMAIL=recrutador@exemplo.com

# Entrevista
INTERVIEW_MOCK=true            # true = sem chamadas externas (custo zero). false exige chaves de API
MAX_DURACAO_MIN=20             # duracao de referencia da entrevista (timer)

# LLM (provedor selecionado por env; Fase 3)
LLM_PROVIDER=openrouter        # openrouter | deepseek | anthropic
LLM_MODEL=                     # ex.: anthropic/claude... | deepseek/deepseek-...
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# STT - transcricao de audio (Fase 3)
STT_PROVIDER=groq              # groq | openai
GROQ_API_KEY=
OPENAI_API_KEY=

# TTS - voz do agente (Fase 3)
TTS_PROVIDER=google            # google | openai
GOOGLE_APPLICATION_CREDENTIALS= # caminho do JSON de credenciais
TTS_VOICE=pt-BR-Neural2-A      # voz pt-BR a definir

# E-mail (Fase 4)
RESEND_API_KEY=
