# ──────────────────────────────────────────────────────────────
# Vendedor Mestre - Recrutamento Automatico
# Copie este arquivo para .env e preencha. NUNCA comite o .env real.
# ──────────────────────────────────────────────────────────────

# Servidor
NODE_ENV=development   # development | production. Em prod o Dockerfile/EasyPanel ja injeta "production"
PORT=3000
APP_BASE_URL=https://entrevista.vendedormestre.com.br   # base dos links em e-mails (ex.: link do relatorio)
# Caminho do banco SQLite. Em DEV use o relativo abaixo (a pasta ./data e criada
# automaticamente no boot). Em PRODUCAO (EasyPanel), monte um volume persistente em
# /data e o app aponta para /data/app.db — o Dockerfile ja injeta esse valor e declara
# VOLUME ["/data"], entao o banco SOBREVIVE a redeploys. Nao e preciso setar esta var
# em producao se usar a imagem do Dockerfile.
DATABASE_PATH=./data/app.db
SESSION_SECRET=troque-isto
AGENT_NAME=Vera
RECRUITER_EMAIL=recrutador@exemplo.com

# Painel do recrutador (Fase 5): segredo da URL secreta de acesso ao /admin.
# Acesse uma vez via /admin?secret=ESTE_VALOR; o app grava um cookie assinado (8h) e
# limpa o parametro da URL. Vazio = painel BLOQUEADO. NUNCA comite o valor real.
ADMIN_SECRET=troque-este-valor

# Entrevista
INTERVIEW_MOCK=true            # true = sem chamadas externas (custo zero). false exige chaves de API
MAX_DURACAO_MIN=20             # duracao de referencia da entrevista (timer)
MAX_PERGUNTAS=12               # (modo real) teto de perguntas antes de encerrar
HISTORICO_TURNS_RECENTES=6     # (modo real) qtos turns completos vao ao LLM; os antigos viram resumo curto
PROVIDER_TIMEOUT_MS=30000      # (modo real) timeout por chamada externa (STT/LLM/TTS)

# LLM (so usado quando INTERVIEW_MOCK=false). Default: OpenRouter (gateway unificado,
# API compativel com a da OpenAI — uma chave, varios modelos).
LLM_PROVIDER=openrouter                            # openrouter | anthropic
OPENROUTER_API_KEY=                                # https://openrouter.ai (chave sk-or-v1-...)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # endpoint compativel OpenAI (/chat/completions)
# Dois modelos por tipo de tarefa (o adaptador escolhe pelo opcoes.tarefa; default=complexo):
LLM_MODEL_COMPLEXO=deepseek/deepseek-v4-flash      # perguntas da entrevista e relatorio
LLM_MODEL_SIMPLES=deepseek/deepseek-chat-v3.1      # tarefas leves (classificacao/validacao curta)
# Obs.: o adaptador desabilita o "reasoning" (reasoning.enabled=false) para respostas
# diretas, mais rapidas e baratas (nao gastamos tokens de raciocinio).
ANTHROPIC_API_KEY=                                 # alternativa (chave Anthropic direta)

# STT - transcricao de audio (so usado quando INTERVIEW_MOCK=false). Default: Groq Whisper
STT_PROVIDER=groq                           # groq | openai
GROQ_API_KEY=                               # https://console.groq.com
GROQ_STT_MODEL=whisper-large-v3             # modelo Whisper no Groq
OPENAI_API_KEY=                             # alternativa (Whisper da OpenAI)

# TTS - voz do agente Vera (so usado quando INTERVIEW_MOCK=false). Default: Google Cloud TTS (pt-BR)
TTS_PROVIDER=google                         # google | openai
GOOGLE_TTS_VOICE=pt-BR-Wavenet-A            # baixo custo; upgrade: pt-BR-Chirp3-HD-* (mais caro/natural)
GOOGLE_TTS_LANGUAGE=pt-BR
# Credencial do Google em UMA das duas formas (o adaptador tenta nesta ordem):
GOOGLE_TTS_CREDENTIALS_JSON=                # (1) JSON inteiro da service account numa unica env (ideal p/ EasyPanel)
GOOGLE_APPLICATION_CREDENTIALS=             # (2) caminho do arquivo .json da service account (deixe fora do repo)

# Google Drive (Fase 5) - destino das gravacoes de video. Reusa a credencial do Google
# acima (mesma Service Account). RECOMENDADO em producao: pre-criar a pasta numa conta
# humana (ou Shared Drive), compartilha-la como Editor com o e-mail da Service Account e
# colar o ID dela em GOOGLE_DRIVE_FOLDER_ID (a SA nao tem cota de storage propria).
GOOGLE_DRIVE_FOLDER_ID=                      # id da pasta-destino (vazio = procura/cria pela pasta abaixo)
GOOGLE_DRIVE_FOLDER_NAME=Entrevistas VM      # nome da pasta criada/procurada quando FOLDER_ID vazio

# E-mail (Fase 4) - envio do relatorio ao recrutador. Destinatario = RECRUITER_EMAIL (acima).
RESEND_API_KEY=                                      # https://resend.com (dominio verificado)
RESEND_FROM_EMAIL=relatorios@vendedormestre.com.br   # remetente (precisa ser do dominio verificado)
