# Dependencias
/node_modules

# Dados (volume persistente) - o .db nunca vai pro git
/data/*
!/data/.gitkeep

# Banco SQLite em qualquer lugar (inclui arquivos WAL/SHM)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Segredos
.env
.env.local

# Credenciais Google Cloud (TTS) - NUNCA commitar.
# Prefira GOOGLE_TTS_CREDENTIALS_JSON (env) ou aponte o caminho p/ fora do repo / dentro de /data.
*service-account*.json
*gserviceaccount*.json
google-credentials*.json
gcp-credentials*.json

# Audios gerados (smoke de TTS, etc.)
*.mp3

# Logs e temporarios
*.log
npm-debug.log*
.DS_Store

# Uploads de candidatos (currículos) - chegam na Fase 1
/uploads
